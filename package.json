{
  "name": "npm-package-converter",
  "version": "1.0.0",
  "description": "Convert npm package pages to markdown",
  "main": "index.js",
  "scripts": {
    "start": "electron ."
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "npm-registry-fetch": "^19.1.1"
  },
  "devDependencies": {
    "electron": "^43.1.1",
    "electron-builder": "^26.15.3"
  },
  "build": {
    "appId": "com.kaito.npm-package-converter",
    "productName": "NPM Package Converter",
    "directories": {
      "output": "dist"
    },
    "files": [
      "index.js",
      "preload.js",
      "npm.png",
      "package.json"
    ],
    "win": {
      "target": [
        "portable"
      ],
      "icon": "./npm.ico"
    }
  }
}
